<shad:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Encryptum.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
        mc:Ignorable="d" d:DesignWidth="320"
        x:Class="Encryptum.Views.Dialogs.CreateItemDialog"
        x:DataType="vm:CreateItemViewModel"
        Title="{Binding DialogTitle}"
        Width="320"
        SizeToContent="Height"
        CanResize="false"
        TitleBarAnimationEnabled="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.ico">

    <shad:Window.LogoContent>
        <Image Source="/Assets/icon.png" Width="20" Height="20"/>
    </shad:Window.LogoContent>

    <Border Padding="24">
        <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <LucideIcon Kind="{Binding DialogIcon}" Size="24" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding DialogTitle}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBox Text="{Binding ItemName, Mode=TwoWay}"
                     Watermark="Enter name"
                     KeyDown="OnNameKeyDown"/>

            <TextBlock Text="Name cannot be empty" Foreground="{DynamicResource DestructiveColor}" FontSize="12"
                       IsVisible="{Binding IsNameErrorVisible}"/>

            <StackPanel Spacing="8" IsVisible="{Binding IsFileMode}">
                <TextBlock Text="Format" FontSize="13" Opacity="0.6"/>
                <ComboBox ItemsSource="{x:Static vm:CreateItemViewModel.FileFormats}"
                          SelectedIndex="{Binding SelectedFormatIndex, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Command="{Binding CancelCommand}" Classes="Outline" Content="Cancel" Padding="16,6"/>
                <Button Command="{Binding CreateCommand}" Classes="Primary" Content="Create" Padding="16,6"/>
            </StackPanel>
        </StackPanel>
    </Border>

</shad:Window>