<shad:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Encryptum.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
        mc:Ignorable="d" d:DesignWidth="320"
        x:Class="Encryptum.Views.Dialogs.RenameDialog"
        x:DataType="vm:RenameViewModel"
        Title="Rename"
        Width="320"
        SizeToContent="Height"
        CanResize="false"
        TitleBarAnimationEnabled="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.ico">

    <shad:Window.LogoContent>
        <Image Source="/Assets/icon.png" Width="20" Height="20"/>
    </shad:Window.LogoContent>

    <Border Padding="24">
        <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <LucideIcon Kind="PenLine" Size="24" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Rename" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBox Text="{Binding NewName, Mode=TwoWay}"
                     Watermark="Enter new name"
                     KeyDown="OnNameKeyDown"/>

            <TextBlock Text="Name cannot be empty" Foreground="{DynamicResource DestructiveColor}" FontSize="12"
                       IsVisible="{Binding IsNameErrorVisible}"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Command="{Binding CancelCommand}" Classes="Outline" Content="Cancel" Padding="16,6"/>
                <Button Command="{Binding ConfirmCommand}" Classes="Primary" Content="Rename" Padding="16,6"/>
            </StackPanel>
        </StackPanel>
    </Border>

</shad:Window>