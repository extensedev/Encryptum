<shad:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Encryptum.ViewModels.Dialogs"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
        mc:Ignorable="d" d:DesignWidth="340"
        x:Class="Encryptum.Views.Dialogs.DeleteConfirmDialog"
        x:DataType="vm:DeleteConfirmViewModel"
        Title="Confirm Delete"
        Width="340"
        SizeToContent="Height"
        CanResize="false"
        TitleBarAnimationEnabled="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.ico">

    <shad:Window.LogoContent>
        <Image Source="/Assets/icon.png" Width="20" Height="20"/>
    </shad:Window.LogoContent>

    <Border Padding="24">
        <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <LucideIcon Kind="TriangleAlert" Size="24" Foreground="{DynamicResource DestructiveColor}" VerticalAlignment="Center"/>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Delete" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="{Binding Message}" FontSize="14" TextWrapping="Wrap" Opacity="0.85"/>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Command="{Binding CancelCommand}" Classes="Outline" Content="Cancel" Padding="16,6"/>
                <Button Command="{Binding DeleteCommand}" Classes="Destructive" Content="Delete" Padding="16,6"/>
            </StackPanel>
        </StackPanel>
    </Border>

</shad:Window>