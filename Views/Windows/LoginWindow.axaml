<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Encryptum.ViewModels.Windows"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shadui="using:ShadowUI"
        mc:Ignorable="d" d:DesignWidth="520"
        x:Class="Encryptum.Views.Windows.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Encryptum"
        Width="560"
        SizeToContent="Height"
        CanResize="false"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico">

    <DockPanel>
    <shadui:TitleBar x:Name="Chrome" DockPanel.Dock="Top" Title="Encryptum" ShowMaximize="False" IconSize="20">
        <shadui:TitleBar.Icon>
            <Image Source="/Assets/icon.png"/>
        </shadui:TitleBar.Icon>
    </shadui:TitleBar>

    <shadui:Card HorizontalAlignment="Center" Margin="24,20">
        <StackPanel Width="480" Spacing="12">

            <StackPanel Spacing="4" Margin="0,0,0,8">
                <shadui:CardTitle Content="Unlock vault"/>
                <shadui:CardDescription Content="Enter your password to access encrypted files."/>
            </StackPanel>

            <Panel Height="88">
                <Border IsVisible="{Binding ShowInfoBanner}"
                        Background="{DynamicResource ShadowCardBrush}"
                        BorderBrush="{DynamicResource ShadowMutedForegroundBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <LucideIcon Kind="Info" Size="16" Foreground="{DynamicResource ShadowMutedForegroundBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Creating a new vault" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="The password you enter will be used to encrypt your vault. Please choose a strong password that you won't forget — it cannot be recovered."
                                   FontSize="13" TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding IsErrorVisible}"
                        Background="{DynamicResource ShadowCardBrush}"
                        BorderBrush="{DynamicResource ShadowDestructiveBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <LucideIcon Kind="CircleAlert" Size="16" Foreground="{DynamicResource ShadowDestructiveBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Unlock failed" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ShadowDestructiveBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="13" TextWrapping="Wrap" Opacity="0.9"/>
                    </StackPanel>
                </Border>
            </Panel>

            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Classes="outline" Height="36" FontSize="13"
                    Click="OnKeyboardToggle">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <LucideIcon Kind="Keyboard" Size="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Virtual Keyboard" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
            </Button>

            <Panel x:Name="KeyboardPanel" IsVisible="False">
                <Border Background="{DynamicResource ShadowCardBrush}"
                        BorderBrush="{DynamicResource ShadowBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">

                        <ItemsControl ItemsSource="{Binding KeyRow1}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="30" Height="38" Padding="0" FontSize="12" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding KeyRow2}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="38" Height="40" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding KeyRow3}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="38" Height="40" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding KeyRow4}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="38" Height="40" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{Binding KeyRow5}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                        <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="36" Height="38" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="outline"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Command="{Binding BackspaceCommand}" Width="52" Height="38" Padding="0" ToolTip.Tip="Backspace">
                                <LucideIcon Kind="Delete" Size="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <Button Command="{Binding InputCharCommand}" CommandParameter=" " Width="240" Height="38" FontSize="13" Content="Space" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Panel>

            <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                <TextBox Grid.Column="0"
                         x:Name="PasswordBox"
                         Text="{Binding Password, Mode=TwoWay}"
                         PlaceholderText="Password"
                         PasswordChar="•"
                         IsVisible="{Binding !IsPasswordVisible}"
                         KeyDown="OnPasswordKeyDown"/>
                <TextBox Grid.Column="0"
                         Text="{Binding Password, Mode=TwoWay}"
                         PlaceholderText="Password"
                         IsVisible="{Binding IsPasswordVisible}"
                         KeyDown="OnPasswordKeyDown"/>
                <Button Grid.Column="1" Command="{Binding TogglePasswordCommand}" Classes="ghost icon" VerticalAlignment="Center" Margin="4,0,0,0">
                    <Panel>
                        <LucideIcon Kind="Eye" Size="16" IsVisible="{Binding !IsPasswordVisible}"/>
                        <LucideIcon Kind="EyeOff" Size="16" IsVisible="{Binding IsPasswordVisible}"/>
                    </Panel>
                </Button>
            </Grid>
            <Button Content="{Binding UnlockButtonText}"
                    Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Height="40" FontSize="14"/>
        </StackPanel>
    </shadui:Card>
    </DockPanel>

</Window>