<shad:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Encryptum.ViewModels.Windows"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
        mc:Ignorable="d" d:DesignWidth="520"
        x:Class="Encryptum.Views.Windows.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Encryptum"
        Width="520"
        SizeToContent="Height"
        CanResize="false"
        TitleBarAnimationEnabled="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico">

    <shad:Window.LogoContent>
        <Image Source="/Assets/icon.png" Width="20" Height="20"/>
    </shad:Window.LogoContent>

    <Border Padding="24,20" HorizontalAlignment="Center">
        <StackPanel Width="480" Spacing="12">

            <Border IsVisible="{Binding IsNewVault}"
                    Background="{DynamicResource CardBackgroundColor}"
                    BorderBrush="{DynamicResource MutedColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <LucideIcon Kind="Info" Size="16" Foreground="{DynamicResource MutedColor}" VerticalAlignment="Center"/>
                        <TextBlock Text="Creating a new vault" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="The password you enter will be used to encrypt your vault. Please choose a strong password that you won't forget — it cannot be recovered."
                               FontSize="13" TextWrapping="Wrap" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Classes="Outline" Height="36" FontSize="13"
                    Click="OnKeyboardToggle">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <LucideIcon Kind="Keyboard" Size="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Virtual Keyboard" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
            </Button>

            <Panel x:Name="KeyboardPanel" IsVisible="False">
                <Border Background="{DynamicResource CardBackgroundColor}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">

                        <ItemsControl ItemsSource="{Binding KeyRow1}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="30" Height="38" Padding="0" FontSize="12" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="Outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding KeyRow2}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="38" Height="40" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="Outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding KeyRow3}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="38" Height="40" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="Outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding KeyRow4}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                    <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="38" Height="40" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="Outline"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{Binding KeyRow5}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:KeyButtonViewModel">
                                        <Button Content="{Binding Key}" Command="{Binding PressCommand}" Width="36" Height="38" Padding="0" FontSize="14" FontFamily="Consolas,monospace" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Classes="Outline"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Command="{Binding BackspaceCommand}" Width="52" Height="38" Padding="0" ToolTip.Tip="Backspace">
                                <LucideIcon Kind="Delete" Size="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <Button Command="{Binding InputCharCommand}" CommandParameter=" " Width="240" Height="38" FontSize="13" Content="Space" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Panel>

            <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                <TextBox Grid.Column="0"
                         x:Name="PasswordBox"
                         Text="{Binding Password, Mode=TwoWay}"
                         Watermark="Password"
                         PasswordChar="•"
                         IsVisible="{Binding !IsPasswordVisible}"
                         KeyDown="OnPasswordKeyDown"/>
                <TextBox Grid.Column="0"
                         Text="{Binding Password, Mode=TwoWay}"
                         Watermark="Password"
                         IsVisible="{Binding IsPasswordVisible}"
                         KeyDown="OnPasswordKeyDown"/>
                <Button Grid.Column="1" Command="{Binding TogglePasswordCommand}" Classes="Ghost" Width="36" Height="36" Padding="0" VerticalAlignment="Center" Margin="4,0,0,0">
                    <Panel>
                        <LucideIcon Kind="Eye" Size="16" IsVisible="{Binding !IsPasswordVisible}"/>
                        <LucideIcon Kind="EyeOff" Size="16" IsVisible="{Binding IsPasswordVisible}"/>
                    </Panel>
                </Button>
            </Grid>
            <Button Content="{Binding UnlockButtonText}"
                    Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Classes="Primary" Height="40" FontSize="14"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DestructiveColor}"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding IsErrorVisible}"/>
        </StackPanel>
    </Border>

</shad:Window>